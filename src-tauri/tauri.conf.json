{
  "$schema": "https://raw.githubusercontent.com/nicerdicer/tauri-docs-v2/refs/heads/dev/packages/tauri-schema/schema.json",
  "productName": "FileSense",
  "version": "0.1.0",
  "identifier": "com.filesense.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "FileSense",
        "width": 680,
        "height": 500,
        "center": true,
        "transparent": true,
        "decorations": true,
        "alwaysOnTop": true,
        "visible": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:9274"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": null
    },
    "externalBin": ["binaries/filesense-python"]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
